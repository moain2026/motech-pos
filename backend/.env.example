# Motech POS Backend — environment template (12-Factor). Copy to .env (gitignored).

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=info

# --- Oracle (read-only phase) ---
# node-oracledb thin mode — no Instant Client required.
ORACLE_USER=MOTECH_RO
ORACLE_PASSWORD=motech_ro_2026
ORACLE_CONNECT_STRING=127.0.0.1:1521/xe
# Schema that owns the real POS tables (queries are schema-qualified).
ORACLE_SCHEMA=YSPOS23
# Connection pool
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=4
ORACLE_POOL_TIMEOUT=60
