# Motech POS Backend — environment template (12-Factor). Copy to .env (gitignored).

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=info

# --- Oracle (read-only phase) ---
# node-oracledb thin mode — no Instant Client required.
ORACLE_USER=MOTECH_RO
ORACLE_PASSWORD=motech_ro_2026
ORACLE_CONNECT_STRING=127.0.0.1:1521/xe
# Schema that owns the real POS tables (queries are schema-qualified).
ORACLE_SCHEMA=YSPOS23
# Connection pool
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=4
ORACLE_POOL_TIMEOUT=60

# --- Oracle WRITE side (our own schema MOTECH_POS — NEVER writes to YSPOS23) ---
# The new system reads reference data from YSPOS23 (MOTECH_RO) but writes its own
# bills/payments/shifts here. Created by db/migrations/V001..V002.
ORACLE_WRITE_USER=MOTECH_POS
ORACLE_WRITE_PASSWORD=motech_pos_2026
ORACLE_WRITE_SCHEMA=MOTECH_POS

# --- Auth / JWT ---
# Use a long random secret in real deployments (e.g. `openssl rand -hex 32`).
# Generate: openssl rand -base64 48  (min 32 chars; dev/template values are rejected at boot)
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=motech-pos
# Local (TEMPORARY) users seed — bcrypt-hashed passwords. See auth module docs.
AUTH_USERS_FILE=auth-users.json
