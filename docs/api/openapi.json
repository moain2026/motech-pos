    "info": {
        "title": "Motech POS API",
        "description": "NestJS backend (Oracle-first, Clean/Hexagonal)",
        "version": "0.2.0",
        "contact": {}
    },
    "tags": [],
    "servers": [],
    "components": {
        "securitySchemes": {
            "bearer": {
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "type": "http"
            }
        },
        "schemas": {
            "LoginDto": {
                "type": "object",
                "properties": {
                    "username": {
                        "type": "string",
                        "example": "cashier1"
                    },
                    "password": {
                        "type": "string",
                        "example": "cashier123"
                    }
                },
                "required": [
                    "username",
                    "password"
                ]
            },
            "RefreshDto": {
                "type": "object",
                "properties": {
                    "refreshToken": {
                        "type": "string"
                    }
                },
                "required": [
                    "refreshToken"
                ]
            },
            "OpenShiftDto": {
                "type": "object",
                "properties": {
                    "cashierNo": {
                        "type": "number",
                        "example": 12,
                        "description": "Cashier number (CSHR_NO)"
                    },
                    "shiftCode": {
                        "type": "string",
                        "example": "M",
                        "description": "Shift code (POS_WRK_SHFT)"
                    },
                    "machineNo": {
                        "type": "number",
                        "example": 1,
                        "description": "POS machine number"
                    },
                    "openingBalance": {
                        "type": "number",
                        "example": 1000,
                        "description": "Opening cash balance"
                    },
                    "currency": {
                        "type": "string",
                        "example": "YER"
                    }
                },
                "required": [
                    "cashierNo"
                ]
            },
            "CloseShiftDto": {
                "type": "object",
                "properties": {
                    "closingBalance": {
                        "type": "number",
                        "example": 4250.5,
                        "description": "Counted closing cash (defaults to expected if omitted)"
                    },
                    "closeNote": {
                        "type": "string",
                        "example": "End of morning shift"
                    }
                }
            },
            "PostBillLineDto": {
                "type": "object",
                "properties": {
                    "itemCode": {
                        "type": "string",
                        "example": "100001",
                        "description": "Item code (YSPOS23 I_CODE)"
                    },
                    "qty": {
                        "type": "number",
                        "example": 2
                    },
                    "unitPrice": {
                        "type": "number",
                        "example": 150,
                        "description": "Override price (else reference)"
                    },
                    "discDtl": {
                        "type": "number",
                        "example": 0,
                        "description": "Per-unit detail discount"
                    },
                    "freeQty": {
                        "type": "number",
                        "example": 0
                    },
                    "vatPercent": {
                        "type": "number",
                        "example": 15,
                        "description": "Override VAT% (else reference)"
                    }
                },
                "required": [
                    "itemCode",
                    "qty"
                ]
            },
            "PostBillDto": {
                "type": "object",
                "properties": {
                    "cashierNo": {
                        "type": "number",
                        "example": 12,
                        "description": "Cashier number (must have open shift)"
                    },
                    "machineNo": {
                        "type": "number",
                        "example": 1
                    },
                    "customerCode": {
                        "type": "string",
                        "example": "C001"
                    },
                    "customerName": {
                        "type": "string",
                        "example": "Walk-in"
                    },
                    "currency": {
                        "type": "string",
                        "example": "YER"
                    },
                    "taxCalcType": {
                        "type": "number",
                        "example": 2,
                        "enum": [
                            1,
                            2
                        ],
                        "description": "1=on price, 2=after discount"
                    },
                    "headerDiscount": {
                        "type": "number",
                        "example": 0,
                        "description": "Header discount allocated across lines"
                    },
                    "clientOperationId": {
                        "type": "string",
                        "example": "018f2c1a-...uuidv7",
                        "description": "Client op id"
                    },
                    "lines": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/PostBillLineDto"
                        }
                    }
                },
                "required": [
                    "cashierNo",
                    "lines"
                ]
            },
            "AddPaymentDto": {
                "type": "object",
                "properties": {
                    "method": {
                        "type": "string",
                        "example": "CASH",
                        "enum": [
                            "CASH",
                            "CARD",
                            "CREDIT"
                        ]
                    },
                    "amount": {
                        "type": "number",
                        "example": 300
                    },
                    "currency": {
                        "type": "string",
                        "example": "YER"
                    },
                    "rate": {
                        "type": "number",
                        "example": 1,
                        "description": "Exchange rate to bill currency"
                    },
                    "cardNo": {
                        "type": "string",
                        "example": "****1234"
                    },
                    "customerCode": {
                        "type": "string",
                        "example": "C001"
                    }
                },
                "required": [
                    "method",
                    "amount"
                ]
            }
        }
    }
}